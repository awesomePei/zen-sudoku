{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:worker\"",
    "dev:frontend": "vite --port=5173",
    "dev:worker": "wrangler dev --local",
    "dev:server": "tsx server/index.ts",
    "build": "vite build",
    "build:worker": "npm run lint",
    "deploy": "wrangler deploy",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/cors": "^2.8.19",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^8.2.0",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "hono": "^4.12.8",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^9.0.0",
    "vite": "^6.2.0",
    "wrangler": "^4.76.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
