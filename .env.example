# Server Configuration (for local Node.js server)
NODE_PORT=3001
DB_PATH=./data/sudoku.db
NODE_ENV=development

# Frontend Development
# For Cloudflare Workers: http://localhost:8787
# For Node.js server: http://localhost:3001
VITE_API_URL=http://localhost:8787
API_URL=http://localhost:8787

# Gemini API (if using AI features)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Cloudflare Workers Deployment (optional)
# CLOUDFLARE_ACCOUNT_ID=your_account_id
# CLOUDFLARE_API_TOKEN=your_api_token
